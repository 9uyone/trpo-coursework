@page "/"
@using TRPO_Coursework.Services
@using TRPO_Coursework.Models
@using TRPO_Coursework.Enums
@inject SimulationService Simulation
@implements IDisposable

<PageTitle>ЦУМ: Симуляція кас</PageTitle>

<h4>Каси</h4>
@foreach (var item in Simulation.CashDesks)
{
	<div>
    Каса @(item.Id): @(item.IsBusy ? $"Покупець #{item.CurrentCustomer.Id}" : "Вільна")
</div>
}<br />

<p>
	<button class="btn btn-primary" @onclick="() => Simulation.Start()">Старт</button>
	<button class="btn btn-primary" @onclick="() => Simulation.Stop()">Стоп</button>
</p>

<p>
	Черга: @Simulation.Stats.QueueLength<br />
	Обслужено: @Simulation.Stats.TotalCustomersServed<br />
	Максимальна довжина черги: @Simulation.Stats.MaxLength<br />
	Середня довжина черги: @Simulation.Stats.AverageLength<br />
</p>

<h4>Налаштування симуляції</h4>
<div>
	<div>
		<label>Прискорення часу: @speedUp x</label><br />
		<input type="range" disabled="@Simulation.Running" class="long-slider" min="1" max="1000" step="1" @bind="speedUp" @bind:event="oninput" @bind:after="ApplySettings" />
	</div>

	<div>
		<label>Генерація покупців (сек): від @generationMin до @generationMax</label><br />
		<input type="range" class="long-slider" min="10" max="1200" step="10" @bind="generationMin" @bind:event="oninput" @bind:after="ApplySettings" />
		<input type="range" class="long-slider" min="10" max="1200" step="10" @bind="generationMax" @bind:event="oninput" @bind:after="ApplySettings" />
	</div>

	<div>
		<label>Обслуговування (сек): від @servingMin до @servingMax</label><br />
		<input type="range" class="long-slider" min="10" max="1200" step="10" @bind="servingMin" @bind:event="oninput" @bind:after="ApplySettings" />
		<input type="range" class="long-slider" min="10" max="1200" step="10" @bind="servingMax" @bind:event="oninput" @bind:after="ApplySettings" />
	</div>
</div>

<div class="accordion mb-3" id="customerTableAccordion">
	<div class="accordion-item">
		<h2 class="accordion-header" id="customerTableHeading">
			<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#customerTableCollapse" aria-expanded="false" aria-controls="customerTableCollapse">
				Часи обслуговування клієнтів (останні 100)
			</button>
		</h2>
		<div id="customerTableCollapse" class="accordion-collapse collapse" aria-labelledby="customerTableHeading" data-bs-parent="#customerTableAccordion">
			<div class="accordion-body">
				@if (Simulation.CustomerEntries.IsEmpty())
				{
					<p>Ще немає завершених обслуговувань.</p>
				}
				else
				{
					<div class="table-responsive">
						<table class="table table-sm table-striped align-middle">
							<thead>
								<tr>
									<th>Клієнт</th>
									<th>Очікування</th>
									<th>Обслуговування</th>
									<th>Всього</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var customer in Simulation.CustomerEntries.ToList().OrderByDescending(x => x.ServiceFinishedAt))
								{
									<tr>
										<td>#@customer.Id</td>
										<td>@FormatSeconds(customer.WaitingTime * Simulation.SpeedUpTimes)</td>
										<td>@FormatSeconds(customer.ServiceTime * Simulation.SpeedUpTimes)</td>
										<td>@FormatSeconds(customer.TotalTime * Simulation.SpeedUpTimes)</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			</div>
		</div>
	</div>
</div>

<div class="accordion mb-3" id="logAccordion">
	<div class="accordion-item">
		<h2 class="accordion-header" id="logHeading">
			<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#logCollapse" aria-expanded="false" aria-controls="logCollapse">
				Журнал подій (1000 останніх)
			</button>
		</h2>
		<div id="logCollapse" class="accordion-collapse collapse" aria-labelledby="logHeading" data-bs-parent="#logAccordion">
			<div class="accordion-body">
				@if (Simulation.LogEntries.IsEmpty())
				{
					<p>Поки що подій немає.</p>
				}
				else
				{
					<ul class="mb-0">
						@foreach (var entry in Simulation.LogEntries.ToList().OrderByDescending(x => x.Timestamp))
						{
							<li>
								@entry.Timestamp.ToString("HH:mm:ss") — @FormatEvent(entry)
							</li>
						}
					</ul>
				}
			</div>
		</div>
	</div>
</div>

@code {
	private Action? handler;
	private int speedUp;
	private int generationMin;
	private int generationMax;
	private int servingMin;
	private int servingMax;

	protected override void OnInitialized()
	{
		handler = async () => await InvokeAsync(StateHasChanged);
		Simulation.OnChange += handler;

		speedUp = (int)Simulation.SpeedUpTimes;
		(generationMin, generationMax) = ((int)Simulation.GenerationIntervalMs.Item1, (int)Simulation.GenerationIntervalMs.Item2);
		(servingMin, servingMax) = ((int)Simulation.ServingIntervalMs.Item1, (int)Simulation.ServingIntervalMs.Item2);
	}

	public void Dispose()
	{
		if (handler != null)
			Simulation.OnChange -= handler;
	}

	private void ApplySettings()
	{
		if (generationMin > generationMax)
			generationMax = generationMin;

		if (servingMin > servingMax)
			servingMax = servingMin;

		if (speedUp < 1)
			speedUp = 1;

		Simulation.SpeedUpTimes = (uint)speedUp;
		Simulation.GenerationIntervalMs = ((uint)generationMin, (uint)generationMax);
		Simulation.ServingIntervalMs = ((uint)servingMin, (uint)servingMax);
	}

	private static string FormatSeconds(TimeSpan value) => $"{value.TotalSeconds:F1} с";

	private static string FormatEvent(LogEntry entry)
	{
		var customer = entry.CustomerId.HasValue ? $", покупець #{entry.CustomerId.Value}" : string.Empty;
		var cashDesk = entry.CashDeskId.HasValue ? $", каса #{entry.CashDeskId.Value}" : string.Empty;

		return entry.Event switch
		{
			EventType.SimulationStarted => "Симуляцію запущено",
			EventType.SimulationStopped => "Симуляцію зупинено",
			EventType.CustomerEnqueued => $"Покупця додано в чергу{customer}",
			EventType.CustomerDequeued => $"Покупця взято з черги{customer}{cashDesk}",
			EventType.ServiceStarted => $"Почато обслуговування{customer}{cashDesk}",
			EventType.ServiceFinished => $"Завершено обслуговування{customer}{cashDesk}",
			EventType.CustomerNotEnqueued => $"Не вдалося взяти покупця з черги{cashDesk}",
			_ => "Невідома подія"
		};
	}
}
